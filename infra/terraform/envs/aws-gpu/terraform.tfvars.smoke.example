# Minimal single-GPU smoke test for validating your AWS account and pipeline.
# Copy to terraform.tfvars and replace every placeholder before use.

region              = "us-east-1"
public_subnet_cidrs = ["10.42.1.0/24", "10.42.2.0/24"]
availability_zones  = ["us-east-1a", "us-east-1b"]
admin_cidrs         = ["YOUR.PUBLIC.IP.ADDRESS/32"]

controller_ami_id    = "ami-xxxxxxxxxxxxxxxxx"
# Leave worker_ami_id unset to use AWS's latest official Ubuntu 22.04 GPU DLAMI.
# worker_ami_id      = "ami-xxxxxxxxxxxxxxxxx"
key_name             = "your-ec2-keypair"
cluster_token        = "replace-me-with-a-long-random-string"
artifact_bucket_name = "replace-me-with-a-unique-bucket-name"

controller_instance_type = "t3.large"
controller_hourly_rate   = 0.0832

worker_pools = [
  {
    gpu_class     = "T4"
    instance_type = "g4dn.xlarge"
    hourly_rate   = 0.526
    count         = 1
  },
]

benchmark_run_id = "smoke-test-001"

tags = {
  Course = "MSML605"
  Team   = "Sahil-Rahul"
  Stage  = "smoke-test"
}
