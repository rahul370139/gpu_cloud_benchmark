{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Throughput by GPU",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "benchmark_throughput",
          "legendFormat": "{{gpu_type}} / {{workload}} / bs{{batch_size}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "Latency P95 (ms)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "benchmark_latency_p95_ms",
          "legendFormat": "{{gpu_type}} / {{workload}} / bs{{batch_size}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "benchmark_gpu_utilization_pct",
          "legendFormat": "{{gpu_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Memory Used (MB)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "benchmark_gpu_memory_used_mb",
          "legendFormat": "{{gpu_type}} / {{workload}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "title": "Cost Efficiency Overview",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "benchmark_throughput / on(gpu_type) group_left benchmark_cost_per_hour",
          "legendFormat": "{{gpu_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gpu", "benchmark", "ml"],
  "templating": {
    "list": [
      {
        "name": "gpu_type",
        "type": "query",
        "query": "label_values(benchmark_throughput, gpu_type)",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "workload",
        "type": "query",
        "query": "label_values(benchmark_throughput, workload)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GPU Cloud Benchmark Dashboard",
  "uid": "gpu-cloud-benchmark"
}
